# Polyculy Test App — Environment Configuration
# Copy this file to .env and update values for your environment.

# Base URL of the deployed Polyculy instance
POLYCULY_BASE_URL=http://localhost:5000

# Test mode: 'local' | 'staging' | 'production'
POLYCULY_TEST_MODE=local

# Primary seed admin user credentials (pre-seeded user "You")
POLYCULY_SEED_ADMIN_EMAIL=you@polyculy.demo
POLYCULY_SEED_ADMIN_PASSWORD=demo123

# Secondary seed user credentials (Riley — connected to admin)
POLYCULY_SEED_RILEY_EMAIL=riley@polyculy.demo
POLYCULY_SEED_RILEY_PASSWORD=demo123

# Additional seed users
POLYCULY_SEED_JAMIE_EMAIL=jamie@polyculy.demo
POLYCULY_SEED_JAMIE_PASSWORD=demo123
POLYCULY_SEED_ALEX_EMAIL=alex@polyculy.demo
POLYCULY_SEED_ALEX_PASSWORD=demo123

# Prefix for transient test data (used for create-and-clean flows)
POLYCULY_TEST_USER_PREFIX=e2etest_

# Report output directory (relative to project root)
POLYCULY_REPORT_DIR=reports/html

# Browser settings
POLYCULY_HEADLESS=true
POLYCULY_BROWSER=chromium
POLYCULY_SLOW_MO=0

# Timeout settings (in milliseconds)
POLYCULY_ACTION_TIMEOUT=10000
POLYCULY_NAVIGATION_TIMEOUT=15000
POLYCULY_TEST_TIMEOUT=60000

# Screenshot and trace settings
POLYCULY_SCREENSHOT_ON_FAILURE=true
POLYCULY_TRACE_ON_FAILURE=true
POLYCULY_VIDEO=off
